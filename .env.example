# ===== Copy this file to ".env" and fill values =====

# Video language: "en" (English) or "hi" (Hindi)
# NOTE: variable is VIDEO_LANG (plain LANG collides with a Linux system var).
VIDEO_LANG=en

# Trending region for topic selection (IN = India, US, GB, etc.)
TREND_GEO=IN

# Content mode: "evergreen" (SAFE factual topics - recommended, lowest policy risk)
# or "trending" (today's Google Trends, auto-filtered for unsafe topics).
CONTENT_MODE=evergreen

# Pexels API key (FREE - optional). Get from https://www.pexels.com/api/
# If empty, the bot uses an auto-generated gradient background instead of stock footage.
PEXELS_API_KEY=

# Optional: Google Gemini free API key for smarter scripts.
# If empty, the bot writes scripts from Wikipedia/trend data (still free).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# YouTube upload privacy when publishing: "public", "private", or "unlisted"
# Tip: keep "private" until you've reviewed a few generated videos, then switch to "public".
YT_PRIVACY=private

# Set to "true" to actually upload to YouTube. "false" = generate video only (safe test mode).
DO_UPLOAD=false
